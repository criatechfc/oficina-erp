<div class="painel">
  <div class="painel-corpo">
    <form action="<%= modo === 'criar' ? '/clientes' : `/clientes/${cliente._id}?_method=PUT` %>" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-linha mb-16">
        <div class="form-grupo mb-0">
          <label for="nome">Nome completo *</label>
          <input type="text" id="nome" name="nome" required value="<%= cliente.nome || '' %>">
        </div>
        <div class="form-grupo mb-0">
          <label for="cpf">CPF</label>
          <input type="text" id="cpf" name="cpf" value="<%= cliente.cpf || '' %>">
        </div>
        <div class="form-grupo mb-0">
          <label for="rg">RG</label>
          <input type="text" id="rg" name="rg" value="<%= cliente.rg || '' %>">
        </div>
      </div>

      <div class="form-linha mb-16">
        <div class="form-grupo mb-0">
          <label for="telefone">Telefone</label>
          <input type="tel" id="telefone" name="telefone" value="<%= cliente.telefone || '' %>">
        </div>
        <div class="form-grupo mb-0">
          <label for="whatsapp">WhatsApp</label>
          <input type="tel" id="whatsapp" name="whatsapp" value="<%= cliente.whatsapp || '' %>">
        </div>
        <div class="form-grupo mb-0">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" value="<%= cliente.email || '' %>">
        </div>
      </div>

      <div class="form-grupo">
        <label for="endereco">Endereço</label>
        <input type="text" id="endereco" name="endereco" value="<%= cliente.endereco || '' %>">
      </div>

      <div class="form-linha mb-16">
        <div class="form-grupo mb-0">
          <label for="cidade">Cidade</label>
          <input type="text" id="cidade" name="cidade" value="<%= cliente.cidade || '' %>">
        </div>
        <div class="form-grupo mb-0">
          <label for="estado">Estado (UF)</label>
          <input type="text" id="estado" name="estado" maxlength="2" value="<%= cliente.estado || '' %>">
        </div>
        <div class="form-grupo mb-0">
          <label for="cep">CEP</label>
          <input type="text" id="cep" name="cep" value="<%= cliente.cep || '' %>">
        </div>
      </div>

      <div class="form-grupo">
        <label for="observacoes">Observações</label>
        <textarea id="observacoes" name="observacoes"><%= cliente.observacoes || '' %></textarea>
      </div>

      <div class="flex gap-12">
        <button type="submit" class="botao botao-primario">Salvar</button>
        <a href="/clientes" class="botao botao-secundario">Cancelar</a>
      </div>
    </form>
  </div>
</div>
