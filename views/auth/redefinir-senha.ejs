<div class="tela-login">
  <div class="caixa-login">
    <div class="logo-login">
      <span class="icone-moto">🏍️</span>
      <span>Oficina ERP</span>
    </div>
    <h1>Redefinir senha</h1>
    <p class="subtitulo">Escolha uma nova senha de acesso</p>

    <% if (mensagemErro) { %><div class="alerta alerta-erro"><%= mensagemErro %></div><% } %>

    <form action="/redefinir-senha/<%= token %>" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-grupo">
        <label for="senha">Nova senha</label>
        <input type="password" id="senha" name="senha" required minlength="8">
        <p class="campo-ajuda">Mín. 8 caracteres, com maiúscula, minúscula e número.</p>
      </div>
      <div class="form-grupo">
        <label for="confirmarSenha">Confirmar nova senha</label>
        <input type="password" id="confirmarSenha" name="confirmarSenha" required minlength="8">
      </div>
      <button type="submit" class="botao botao-primario botao-bloco">Redefinir senha</button>
    </form>
  </div>
</div>
