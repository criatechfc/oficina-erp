<div class="flex-entre mb-16">
  <h2 class="mt-0 mb-0">Usuários</h2>
  <a href="/usuarios/novo" class="botao botao-primario">+ Novo Usuário</a>
</div>

<div class="painel">
  <div class="tabela-wrap">
    <table>
      <thead><tr><th>Nome</th><th>E-mail</th><th>Perfil</th><th>Status</th><th>Último login</th><th></th></tr></thead>
      <tbody>
        <% usuarios.forEach(u => { %>
          <tr>
            <td><%= u.nome %></td>
            <td><%= u.email %></td>
            <td><span class="badge badge-azul"><%= u.perfil %></span></td>
            <td><span class="badge <%= u.ativo ? 'badge-verde' : 'badge-vermelho' %>"><%= u.ativo ? 'Ativo' : 'Inativo' %></span></td>
            <td><%= u.ultimoLogin ? new Date(u.ultimoLogin).toLocaleString('pt-BR') : 'Nunca' %></td>
            <td><a href="/usuarios/<%= u._id %>/editar" class="botao botao-secundario botao-pequeno">Editar</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
