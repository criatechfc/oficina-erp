<div class="painel">
  <div class="painel-cabecalho"><h2>Dados da oficina</h2></div>
  <div class="painel-corpo">
    <form action="/configuracoes?_method=PUT" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="flex gap-16 mb-16" style="align-items:center;">
        <% if (config.logo) { %>
          <img src="<%= config.logo %>" style="width:70px;height:70px;border-radius:10px;object-fit:cover;">
        <% } %>
        <div style="flex:1;">
          <label for="logo">Logo da oficina</label>
          <input type="file" id="logo" name="logo" accept="image/*">
        </div>
      </div>

      <div class="form-grupo">
        <label for="nomeOficina">Nome da oficina *</label>
        <input type="text" id="nomeOficina" name="nomeOficina" required value="<%= config.nomeOficina %>">
      </div>

      <div class="form-linha mb-16">
        <div class="form-grupo mb-0">
          <label for="telefone">Telefone</label>
          <input type="tel" id="telefone" name="telefone" value="<%= config.telefone || '' %>">
        </div>
        <div class="form-grupo mb-0">
          <label for="whatsapp">WhatsApp</label>
          <input type="tel" id="whatsapp" name="whatsapp" value="<%= config.whatsapp || '' %>">
        </div>
        <div class="form-grupo mb-0">
          <label for="email">E-mail</label>
          <input type="email" id="email" name="email" value="<%= config.email || '' %>">
        </div>
      </div>

      <div class="form-grupo">
        <label for="endereco">Endereço</label>
        <input type="text" id="endereco" name="endereco" value="<%= config.endereco || '' %>">
      </div>

      <div class="form-grupo">
        <label for="tema">Tema padrão</label>
        <select id="tema" name="tema">
          <option value="claro" <%= config.tema === 'claro' ? 'selected' : '' %>>Claro</option>
          <option value="escuro" <%= config.tema === 'escuro' ? 'selected' : '' %>>Escuro</option>
        </select>
      </div>

      <button type="submit" class="botao botao-primario">Salvar configurações</button>
    </form>
  </div>
</div>

<div class="painel">
  <div class="painel-cabecalho"><h2>Backup de dados</h2></div>
  <div class="painel-corpo">
    <p class="texto-suave">Todos os dados do sistema estão armazenados no MongoDB Atlas, que realiza backups automáticos contínuos conforme o plano contratado. Para exportar dados específicos, utilize a seção <a href="/relatorios">Relatórios</a>, que permite exportação em Excel.</p>
    <% if (config.ultimoBackup) { %>
      <p class="texto-pequeno texto-suave">Último backup manual registrado: <%= new Date(config.ultimoBackup).toLocaleString('pt-BR') %></p>
    <% } %>
  </div>
</div>
