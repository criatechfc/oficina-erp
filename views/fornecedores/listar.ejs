<div class="flex-entre mb-16">
  <div class="barra-filtros" style="flex:1;">
    <form method="GET" action="/fornecedores">
      <input type="search" name="busca" placeholder="Buscar por empresa ou CNPJ..." value="<%= busca %>">
      <button type="submit" class="botao botao-secundario">Buscar</button>
    </form>
  </div>
  <a href="/fornecedores/novo" class="botao botao-primario">+ Novo Fornecedor</a>
</div>

<div class="painel">
  <div class="tabela-wrap">
    <table>
      <thead><tr><th>Empresa</th><th>Contato</th><th>Telefone</th><th>CNPJ</th><th></th></tr></thead>
      <tbody>
        <% if (!fornecedores.length) { %>
          <tr><td colspan="5" class="estado-vazio">Nenhum fornecedor encontrado.</td></tr>
        <% } %>
        <% fornecedores.forEach(f => { %>
          <tr>
            <td><%= f.empresa %></td>
            <td><%= f.contato || '-' %></td>
            <td><%= f.telefone || '-' %></td>
            <td><%= formatarCnpj(f.cnpj) || '-' %></td>
            <td>
              <div class="flex gap-8">
                <a href="/fornecedores/<%= f._id %>/editar" class="botao botao-secundario botao-pequeno">Editar</a>
                <form action="/fornecedores/<%= f._id %>?_method=DELETE" method="POST" data-confirmar="Remover este fornecedor?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="botao botao-perigo botao-pequeno">Excluir</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPaginas > 1) { %>
  <div class="paginacao">
    <% for (let i = 1; i <= totalPaginas; i++) { %>
      <a href="/fornecedores?busca=<%= busca %>&pagina=<%= i %>" class="<%= i === paginaAtual ? 'ativo' : '' %>"><%= i %></a>
    <% } %>
  </div>
<% } %>
